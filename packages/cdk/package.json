{
  "name": "cdk",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "tsc --build --clean",
    "test": "vitest run",
    "test:lambda:watch": "vitest watch --dir tests/lambda",
    "cdk": "cdk",
    "format": "biome format --write lib lambda env-parameters tests *config.* parameter* *.json",
    "lint": "biome lint lib && biome lint lambda"
